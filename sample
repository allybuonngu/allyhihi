            { keys: ["việc làm", "thực tập", "giới thiệu"], ans: "Có, thông qua Trung tâm Hỗ trợ sinh viên và các ngày hội việc làm (Job Fair) thường niên." },
            { keys: ["quân sự", "quốc phòng"], ans: "Sinh viên thường đi học quân sự tập trung tại Trung tâm Giáo dục Quốc phòng và An ninh ở Hòa Lạc." },
            { keys: ["gửi xe", "để xe", "bãi xe"], ans: "Có bãi gửi xe và khu vực sân trường dành cho sinh viên." },
            { keys: ["đồng phục", "áo trường", "áo khoa"], ans: "Bạn có thể mua tại văn phòng Đoàn thanh niên hoặc các đợt mở bán đầu năm học." },
            { keys: ["phản ánh", "góp ý", "chất lượng"], ans: "Qua hòm thư góp ý trực tuyến hoặc các đợt khảo sát lấy ý kiến người học cuối mỗi kỳ." }
        ];

        function handleChat() { 
            const input = document.getElementById('chat-input-text'); 
            const content = document.getElementById('chat-content'); 
            const userText = input.value.trim().toLowerCase();
            if(!userText) return; 
            content.innerHTML += `<div class="msg user">${input.value}</div>`; 
            input.value = ''; 
            setTimeout(() => { 
                let reply = "Xin lỗi, câu này khó quá mình chưa có dữ liệu 😢. Bạn thử dùng các từ khóa như 'học phí', 'ký túc xá', 'tín chỉ', 'thư viện'... xem sao nhé!";
                for (let item of botData) {
                    if (item.keys.some(key => userText.includes(key))) {
                        reply = item.ans;
                        break;
                    }
                }
                content.innerHTML += `<div class="msg bot">${reply}</div>`; 
                content.scrollTop = content.scrollHeight; 
            }, 600); 
        }

        // --- GPA CALCULATOR ---
        function toggleGPA() { const gpaWin = document.getElementById('gpa-window'); gpaWin.style.display = (gpaWin.style.display === 'flex') ? 'none' : 'flex'; }
        function switchTab(tabId) { document.getElementById('tab-calc').style.display = (tabId === 'calc') ? 'block' : 'none'; document.getElementById('tab-target').style.display = (tabId === 'target') ? 'block' : 'none'; document.getElementById('btn-tab-calc').classList.toggle('active', tabId === 'calc'); document.getElementById('btn-tab-target').classList.toggle('active', tabId === 'target'); }
        
        function addSubject() { 
            const subjectList = document.getElementById('subject-list'); 
            const newRow = document.createElement('div'); 
            newRow.className = 'subject-row'; 
            newRow.innerHTML = `<input type="number" class="credit-input" placeholder="TC" min="1"><select class="grade-input"><option value="" disabled selected>Chọn</option><option value="4.0">A+ (4.0)</option><option value="3.7">A (3.7)</option><option value="3.5">B+ (3.5)</option><option value="3.0">B (3.0)</option><option value="2.5">C+ (2.5)</option><option value="2.0">C (2.0)</option><option value="1.5">D+ (1.5)</option><option value="1.0">D (1.0)</option><option value="0.0">F (0.0)</option></select><button class="btn-remove" onclick="removeSubject(this)">✕</button>`; 
            subjectList.insertBefore(newRow, subjectList.querySelector('.gpa-actions')); 
        }
        
        function removeSubject(btn) { if(document.querySelectorAll('.subject-row').length > 1) btn.parentElement.remove(); }
        
        function calculateGPA() {
            const rows = document.querySelectorAll('#tab-calc .subject-row');
            let totalCredits = 0, totalPoints = 0, isValid = true;
            rows.forEach(row => {
                const creditVal = row.querySelector('.credit-input').value;
                const gradeVal = row.querySelector('.grade-input').value;
                if (creditVal && gradeVal) {
                    const credits = parseFloat(creditVal);
                    const grade = parseFloat(gradeVal);
                    if(credits > 0) { totalCredits += credits; totalPoints += (credits * grade); }
                } else if (creditVal || gradeVal) { isValid = false; }
            });
            if (!isValid) { alert("Vui lòng nhập đủ số Tín chỉ và Điểm chữ cho các môn bạn đang điền!"); return; }
            if (totalCredits === 0) { alert("Bạn chưa nhập thông tin môn học hợp lệ nào!"); return; }
            const gpa = totalPoints / totalCredits;
            document.getElementById('final-gpa').innerText = gpa.toFixed(2);
            document.getElementById('gpa-result-box').style.display = 'block';
            document.getElementById('subject-list').scrollTop = 0;
        }

        function calculateTarget() {
            const G0 = parseFloat(document.getElementById('target-g0').value);
            const T0 = parseFloat(document.getElementById('target-t0').value);
            const Tr = parseFloat(document.getElementById('target-tr').value);
            const Gm = parseFloat(document.getElementById('target-gm').value);
            if (isNaN(G0) || isNaN(T0) || isNaN(Tr) || isNaN(Gm)) { alert("Vui lòng nhập đầy đủ 4 thông số!"); return; }
            const x = (Gm * (T0 + Tr) - G0 * T0) / Tr;
            const resultBox = document.getElementById('target-result-box');
            if (x > 4.0) { resultBox.innerHTML = `❌ <strong>Bất khả thi!</strong><br>Bạn cần đạt GPA <strong>${x.toFixed(2)}</strong> cho phần còn lại. Mức này vượt quá trần 4.0, hãy đặt mục tiêu thấp hơn nhé.`; resultBox.style.display = 'block'; return; }
            fireConfetti();
            if (x <= 0) { resultBox.innerHTML = `✅ <strong>Quá dễ dàng!</strong><br>Điểm hiện tại của bạn đã đủ cân mốc mục tiêu này. Hãy cứ học thoải mái nhé!`; resultBox.style.display = 'block'; return; }
            
            const targetVal = (x - 3) * Tr;
            let bestPlan = null, minA = Tr + 1;
            for (let a = 0; a <= Tr; a++) {
                for (let b = 0; b <= Tr - a; b++) {
                    let c = Tr - a - b;
                    if (a + 0.5 * b >= targetVal) {
                        if (a < minA) { minA = a; bestPlan = {a, b, c}; }
                        else if (a === minA && bestPlan) { if (b < bestPlan.b) bestPlan = {a, b, c}; }
                    }
                }
            }
            let html = `🎯 <strong>Khả thi!</strong> Bạn cần đạt GPA <strong>${x.toFixed(2)}</strong> cho ${Tr} tín chỉ còn lại.<br><hr style="margin: 10px 0; border: 0; border-top: 1px dashed var(--primary-red);">`;
            if (x <= 3.0) { html += `Mục tiêu khá dễ thở, bạn chỉ cần điểm trung bình tương đương mức B trở xuống.`; }
            else if (bestPlan) { html += `<strong>Gợi ý lộ trình dễ đạt nhất:</strong><br>• <strong>${bestPlan.a}</strong> tín chỉ điểm A (4.0/3.7)<br>• <strong>${bestPlan.b}</strong> tín chỉ điểm B+ (3.5)<br>• <strong>${bestPlan.c}</strong> tín chỉ điểm B (3.0)`; }
            else { html += `Bạn cần kết hợp với điểm A+ hoặc xem lại số liệu nhập vào.`; }
            resultBox.innerHTML = html; resultBox.style.display = 'block';
        }

        // --- HIỆU ỨNG PHÁO GIẤY ---
        function fireConfetti() { 
            var duration = 2 * 1000; var end = Date.now() + duration; 
            (function frame() { 
                confetti({ particleCount: 5, angle: 60, spread: 55, origin: { x: 0 }, colors: ['#D32F2F', '#FFEBEE'] }); 
                confetti({ particleCount: 5, angle: 120, spread: 55, origin: { x: 1 }, colors: ['#D32F2F', '#FFEBEE'] }); 
                if (Date.now() < end) requestAnimationFrame(frame); 
            }()); 
        }
    </script>
