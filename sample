        function filterScholarships(status, btnElement) {
            const btns = document.querySelectorAll('.s-btn-status');
            btns.forEach(btn => btn.classList.remove('active'));
            btnElement.classList.add('active');

            const cards = document.querySelectorAll('.scholar-card');
            cards.forEach(card => {
                if (status === 'all' || card.getAttribute('data-status') === status) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });

            const wrappers = document.querySelectorAll('.s-category-wrapper');
            wrappers.forEach(wrapper => {
                let hasVisibleCard = false;
                const innerCards = wrapper.querySelectorAll('.scholar-card');
                
                innerCards.forEach(c => {
                    if (c.style.display !== 'none') {
                        hasVisibleCard = true;
                    }
                });

                if (hasVisibleCard) {
                    wrapper.style.display = 'block';
                } else {
                    wrapper.style.display = 'none';
                }
            });
        }

